# Copy to .env.local for local dev and set these in Vercel Environment Variables for prod.

# Vercel Postgres auto-sets this when you create the DB in the dashboard.
DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"

# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""   # same value as VAPID_PUBLIC_KEY, browser-visible
VAPID_SUBJECT="mailto:lou.kailich@acture.de"

# Long random string; Vercel Cron sends this as Authorization: Bearer ...
CRON_SECRET=""

# Timezone used for day boundaries and scheduling.
APP_TIMEZONE="Europe/Berlin"
